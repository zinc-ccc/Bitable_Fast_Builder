# Streamlit Cloud Secrets 模板
# 在 share.streamlit.io → App Settings → Secrets 中粘贴以下内容（填写真实值）

[lark]
app_id = "YOUR_LARK_APP_ID"
app_secret = "YOUR_LARK_APP_SECRET"

[openai]
api_key = "YOUR_DEEPSEEK_API_KEY"
base_url = "https://api.deepseek.com"
model = "deepseek-chat"

[hrbp_dashboard]
app_token = "YOUR_BITABLE_APP_TOKEN"
table_id = "YOUR_WEEKLY_REPORT_TABLE_ID"

[access]
# 老板审阅 & 历史数据视图的访问密码
boss_password = "YOUR_BOSS_PASSWORD"
